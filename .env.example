# SearXNG instance URL
SEARXNG_URL=http://localhost:8080

# OpenAI-compatible API endpoint (required)
LLM_ENDPOINT=https://api.openai.com/v1

# API key (not needed for local LLMs like Ollama)
LLM_API_KEY=sk-your-api-key

# Model name
LLM_MODEL=gpt-4o

# Server port (optional, default 5555)
SERVER_PORT=5555

# Timeout in seconds for SearXNG requests (default 60)
# SEARXNG_TIMEOUT=60

# Timeout in seconds for LLM requests (default 60)
# LLM_TIMEOUT=120
